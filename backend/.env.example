# --- Required for app ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=   # From Supabase Dashboard -> Project Settings -> API -> JWT Secret. Required for /api/chat and other auth-protected endpoints.
# OPENAI_API_KEY=

# --- LLM for /api/chat ---
# Option A – Claude (default)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=sonnet

# Option B – Llama / OpenAI-compatible (OpenRouter recommended for cost; or Groq, Together, Ollama)
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# LLM_API_KEY=sk-or-v1-...
# See docs/OPENROUTER_SETUP.md for step-by-step OpenRouter setup.

# --- Optional ---
# SUPABASE_DB_URL=
# OPENAI_EMBED_MODEL=text-embedding-3-small
# CHUNK_SIZE=400
# CHUNK_OVERLAP=50
# SUMMARY_TOP_K=20
# TRIPLE_CANDIDATE_TOP_K=25
# MAX_CANDIDATE_DOCS=40
# CHUNK_TOP_K=5
