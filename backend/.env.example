# --- Required for app ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=   # From Supabase Dashboard -> Project Settings -> API -> JWT Secret. Required for /api/chat and other auth-protected endpoints.
# OPENAI_API_KEY=

# --- LLM for /api/chat (OpenAI-compatible: OpenRouter, Groq, Ollama, etc.) ---
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# LLM_API_KEY=sk-or-v1-...
# For local Ollama: LLM_BASE_URL=http://localhost:11434/v1, LLM_MODEL=<model>, LLM_API_KEY can be unset or "ollama".
# See docs/OPENROUTER_SETUP.md for OpenRouter setup.

# --- Optional ---
# SUPABASE_DB_URL=
# OPENAI_EMBED_MODEL=text-embedding-3-small
# CHUNK_SIZE=400
# CHUNK_OVERLAP=50
# SUMMARY_TOP_K=20
# TRIPLE_CANDIDATE_TOP_K=25
# MAX_CANDIDATE_DOCS=40
# CHUNK_TOP_K=5
