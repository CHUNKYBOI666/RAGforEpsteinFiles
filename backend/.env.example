# Data sources (default: doc-explorer + biography; use --source hf for HuggingFace)
# DOC_EXPLORER_DB_PATH=./data/epstein-doc-explorer/document_analysis.db
# BIOGRAPHY_DIR=./data/epstein-biography/epstein-biography

# Optional: HuggingFace dataset (only when using --source hf)
# HF_DATASET_NAME=teyler/epstein-files-20k

# Optional: local data dir for raw/index artifacts
# DATA_DIR=./data

# LLM for /chat (required for synthesis; copy to .env and set one of the options below)
# Option A – OpenAI API: set your key and optionally model
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# Option B – Local OpenAI-compatible server (e.g. Ollama)
# OPENAI_API_BASE=http://localhost:11434/v1
# LLM_MODEL=llama2
