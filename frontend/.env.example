# Backend API base URL (optional; defaults to http://localhost:8000)
# VITE_API_URL="http://localhost:8000"

# Supabase Auth (required for sign in / chat). From Supabase Dashboard -> Project Settings -> API.
# VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# VITE_SUPABASE_ANON_KEY="eyJ..."

# Legacy / other
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# APP_URL="MY_APP_URL"
